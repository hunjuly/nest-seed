{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "baseUrl": "./",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "strictBindCallApply": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "paths": {
            "app/*": [
                "projects/apps/gateway/src/*"
            ],
            "common": [
                "projects/libs/common/src/index"
            ],
            "common/test": [
                "projects/libs/common/src/test/index"
            ],
            "config": [
                "projects/apps/config/index"
            ],
            "databases/*": [
                "projects/apps/databases/*"
            ]
        },
    }
}
