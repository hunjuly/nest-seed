{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "compilerOptions": {
        "deleteOutDir": true,
        "webpack": true
    },
    "monorepo": true,
    "projects": {
        "gateway": {
            "type": "application",
            "root": "projects/apps/gateway",
            "entryFile": "main",
            "sourceRoot": "projects/apps/gateway/src",
            "compilerOptions": {
                "tsConfigPath": "projects/apps/gateway/tsconfig.json"
            }
        },
        "common": {
            "type": "library",
            "root": "projects/libs/common",
            "entryFile": "index",
            "sourceRoot": "projects/libs/common/src",
            "compilerOptions": {
                "tsConfigPath": "projects/libs/common/tsconfig.json"
            }
        },
        "core": {
            "type": "library",
            "root": "projects/libs/core",
            "entryFile": "index",
            "sourceRoot": "projects/libs/core/src",
            "compilerOptions": {
                "tsConfigPath": "projects/libs/core/tsconfig.json"
            }
        }
    }
}
